GEMINI_API_KEY=your-gemini-api-key-here

# Optional but recommended
JINA_API_KEY=jina_your-key-here
SERPER_API_KEY=your-key-here

# App settings
MAX_PAGES_PER_COMPETITOR=4
REQUEST_TIMEOUT_SECONDS=15
MAX_TOKENS_PER_CHUNK=6000
DEFAULT_MODEL=gemini-2.0-flash

# These are set automatically by docker-compose
# Only override if running without Docker
DATABASE_URL=postgresql+asyncpg://cim_user:cim_password@localhost:5432/competitor_intel
REDIS_URL=redis://localhost:6379/0