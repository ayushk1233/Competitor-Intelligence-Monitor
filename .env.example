# Copy this file to .env and fill in your keys
# Never commit .env to GitHub

# Required
GEMINI_API_KEY=your-gemini-api-key-here

# Optional but recommended (for cleaner HTML parsing)
# Get free key at: https://jina.ai
JINA_API_KEY=jina_your-key-here

# Optional (for fetching recent news per competitor)
# Get free key at: https://serper.dev
SERPER_API_KEY=your-key-here

# App settings
MAX_PAGES_PER_COMPETITOR=4
REQUEST_TIMEOUT_SECONDS=15
MAX_TOKENS_PER_CHUNK=6000
DEFAULT_MODEL=gemini-2.0-flash