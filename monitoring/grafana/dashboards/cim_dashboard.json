{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Duration (p95) — seconds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(pipeline_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(pipeline_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 2,
      "title": "Gemini API Call Duration (p95) — seconds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(gemini_api_call_duration_seconds_bucket[5m]))",
          "legendFormat": "{{ call_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Gemini Tokens Used — per minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(gemini_tokens_used_total[1m]) * 60",
          "legendFormat": "{{ call_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 4,
      "title": "Scrape Success vs Failure Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(scrape_success_total[5m])",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "rate(scrape_failure_total[5m])",
          "legendFormat": "Failure",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 5,
      "title": "Momentum Score Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(momentum_score_distribution_bucket[10m])",
          "legendFormat": "score <= {{ le }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Active Pipeline Runs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "active_pipeline_runs",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Total Pipelines Completed Today",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "increase(pipelines_total{status='completed'}[24h])",
          "legendFormat": "Completed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      }
    },
    {
      "id": 8,
      "title": "Gemini Error Rate — per minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(gemini_errors_total[1m]) * 60",
          "legendFormat": "{{ error_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["competitor-intel", "llmops"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Competitor Intelligence Monitor — LLMOps Dashboard",
  "uid": "cim-llmops-v1",
  "version": 1
}